{
  "name": "cr-asst",
  "type": "module",
  "version": "2.1.0",
  "packageManager": "pnpm@10.24.0",
  "description": "Review your code changes with AI assistants.",
  "author": "mys1024",
  "license": "MIT",
  "homepage": "https://github.com/mys1024/cr-asst#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/mys1024/cr-asst.git"
  },
  "keywords": [
    "AI",
    "assistant",
    "code review",
    "LLM",
    "CI/CD"
  ],
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "cr-asst": "dist/cli/index.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "cli": "tsx src/cli/index.ts",
    "cli:watch": "tsx watch src/cli/index.ts",
    "build": "unbuild",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:cover": "vitest run --coverage",
    "check": "run-p check:*",
    "check:type": "tsc --noEmit",
    "check:lint": "eslint .",
    "check:format": "prettier --check .",
    "taze": "taze -I",
    "prepare": "simple-git-hooks",
    "release": "bumpp"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.53",
    "@ai-sdk/deepseek": "^1.0.31",
    "@ai-sdk/google": "^2.0.44",
    "@ai-sdk/openai": "^2.0.77",
    "@ai-sdk/xai": "^2.0.39",
    "ai": "^5.0.106",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "core-js": "^3.47.0",
    "dotenv": "^17.2.3",
    "execa": "9.3.1",
    "undici": "7.12.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.15",
    "bump": "^0.2.5",
    "bumpp": "^10.3.2",
    "eslint": "^9.39.1",
    "lint-staged": "^16.2.7",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.7.4",
    "simple-git-hooks": "^2.13.1",
    "taze": "^19.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "unbuild": "^3.6.1",
    "vitest": "^4.0.15"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "esbuild",
      "simple-git-hooks"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check:type && pnpm lint-staged"
  },
  "lint-staged": {
    "*": [
      "eslint --fix .",
      "prettier --write ."
    ]
  }
}
